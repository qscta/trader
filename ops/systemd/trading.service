[Unit]
Description=OKX Trading System Live
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/trader/trading
EnvironmentFile=/etc/trading.env
ExecStart=/home/ubuntu/trader/trading/.venv/bin/gunicorn -c gunicorn.conf.py wsgi:application
Restart=always
RestartSec=10
TimeoutStopSec=920

[Install]
WantedBy=multi-user.target
